# Int64 overflow spec: two's-complement wrap, defined on every platform.
# Also the INT64_MIN / -1 and % -1 hardware-trap guards (was a SIGFPE crash).
set min = -9223372036854775807 - 1
set max = 9223372036854775807
say min
say max
say min / -1
say min % -1
say min - 1
say max + 1
say max * 2
say -min
say 1 << 63
say max & 1
set t = max
t += 1
say t
say (max + 1) == min
